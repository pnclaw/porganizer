# # .NET specific ignores:

## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.playlist

# https://github.com/VerifyTests/Verify
*.received.*

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
**/[Bb]in/
**/[Bb]in/**
**/[Bb]in\\*/
[Oo]bj/
**/[Oo]bj/**
[Ll]og/
.nuke/temp/

# Defensive ignores for odd character-prefixed build folders on WSL/mounted filesystems
**/*[Bb]in/
**/*[Bb]in/**
**/*[Oo]bj/
**/*[Oo]bj/**
**/[Bb]in*/
**/[Bb]in*/**
**/[Dd]ebug*/
**/[Dd]ebug*/**

# vscode
.vscode/

# Visual Studio workspace settings
/.vs/

# Application logs
logs/
artifacts/

# Test output
TestResults/

# Claude
.claude/settings.local.json
CLAUDE.local.md

# Agent skills (generic multi-agent install location — developer-local)
.agents/
.codex

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite / Vue build output
dist/
dist-ssr/
*.local

# TypeScript build info
*.tsbuildinfo

# Environment files (may contain secrets)
.env
.env.local
.env.*.local

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
screenshots/

# Docker volumes (local data)
data/

# macOS
.DS_Store

# JetBrains IDEs
.idea/
